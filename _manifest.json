{
  "manifest_version": 2,
  "version": "2.0.0",
  "name": "B站视频随机推送",
  "description": "B站视频随机推送(QQ小程序卡片) + 视频内容问答",
  "author": {
    "name": "Braisedfish",
    "url": "https://github.com/braisedfisher"
  },
  "license": "MIT",
  "urls": {
    "repository": "https://github.com/braisedfisher/bilibili_trending",
    "homepage": "https://github.com/braisedfisher/bilibili_trending",
    "documentation": "https://github.com/braisedfisher/bilibili_trending",
    "issues": "https://github.com/braisedfisher/bilibili_trending/issues"
  },
  "host_application": {
    "min_version": "1.0.0",
    "max_version": "1.0.0"
  },
  "sdk": {
    "min_version": "2.0.0",
    "max_version": "2.99.99"
  },
  "dependencies": [],
  "capabilities": [
    "send.text",
    "send.forward",
    "send.hybrid",
    "network.http",
    "schedule.task",
    "llm.chat",
    "config.get"
